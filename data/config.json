{
  "llm": {
    "provider": "openai",
    "model": "gpt-4",
    "api_key": null,
    "base_url": null
  },
  "live2d": {
    "model_path": "assets/live2d/biaoqiang",
    "scale": 1.0,
    "default_motion": "idle_01"
  },
  "weather": {
    "default_city": "北京"
