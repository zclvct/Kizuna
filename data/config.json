    "auto_start": false,
    "always_on_top": true,
    "sound_enabled": true,
    "log_level": "INFO"
  },
  "motion": {
    "enable_mood_motion": true,
    "enable_idle_motion": true,
    "idle_interval_seconds": 30
  }
}